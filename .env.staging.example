# Staging — copy to `.env.staging` and use: npm run dev:staging / npm run build:staging
# Vite loads `.env`, `.env.local`, then `.env.staging` (and `.env.staging.local`) for --mode staging

VITE_APP_ENV=staging

# Staging API (no trailing slash)
VITE_API_URL=https://api-staging.example.com

VITE_USE_MOCK=false

# Usually test keys in staging
VITE_STRIPE_KEY=pk_test_your_key

# GitHub Pages project site: /repo-name/ — default / for staging on a normal host
VITE_BASE=/
