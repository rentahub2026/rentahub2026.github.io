# Staging API — copy to `backend/.env.staging` or set the same keys on your host.
# Load order: `.env` → `.env.local` → `.env.staging` (when APP_ENV=staging)

APP_ENV=staging
NODE_ENV=development

PORT=5000

# Staging Postgres
DATABASE_URL="postgresql://user:pass@staging-db.example.com:5432/rentara?schema=public"

# Frontend origin(s) for CORS (comma-separated, no spaces after commas optional)
CORS_ORIGIN=https://yourname.github.io,https://staging-app.example.com
