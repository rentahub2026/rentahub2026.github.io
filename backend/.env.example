# Local API development — see `.env.staging.example` / `.env.production.example` for other APP_ENV files.

APP_ENV=development
NODE_ENV=development

# PostgreSQL (Prisma) — see DEPLOYMENT.md for production URLs
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/rentara?schema=public"

PORT=5000

# Optional local CORS: CORS_ORIGIN=http://localhost:5173

# Firebase Admin (backend) — verify ID tokens from the web app (Authorization: Bearer)
# Matches your Firebase project's project_id.
FIREBASE_PROJECT_ID=rentarah
# Absolute path to the service-account JSON from Firebase Console → Project settings → Service accounts
# Example: GOOGLE_APPLICATION_CREDENTIALS=/Users/you/secrets/rentarah-firebase-adminsdk.json
# GOOGLE_APPLICATION_CREDENTIALS=
