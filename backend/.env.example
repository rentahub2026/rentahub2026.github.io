# PostgreSQL connection string (Prisma)
# Example: postgresql://USER:PASSWORD@localhost:5432/rentara?schema=public
# Production: use your host’s URL + sslmode (or provider-specific params). See DEPLOYMENT.md.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/rentara?schema=public"

# API (many hosts set PORT automatically — the app reads process.env.PORT)
PORT=5000
NODE_ENV=development

# CORS: required in production — comma-separated frontend origins (no trailing slashes)
# Local dev: leave unset to allow flexible origins, or e.g. CORS_ORIGIN=http://localhost:5173
# Production: CORS_ORIGIN=https://yourname.github.io,https://app.yourdomain.com
# CORS_ORIGIN=http://localhost:5173
