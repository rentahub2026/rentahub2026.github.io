# Local development (`npm run dev` — Vite mode: development)
# See `.env.staging.example` / `.env.production.example` for other modes.

VITE_APP_ENV=development

# Stripe test publishable key — https://dashboard.stripe.com/test/apikeys
VITE_STRIPE_KEY=pk_test_your_publishable_key_here

# Backend — no trailing slash. Required when VITE_USE_MOCK=false
VITE_API_URL=http://localhost:5000

# Use mockApi.ts when true; set false to call VITE_API_URL
VITE_USE_MOCK=true

# GitHub Pages project site only: VITE_BASE=/repo-name/
VITE_BASE=/
