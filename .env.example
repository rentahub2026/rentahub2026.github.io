# Local development (`npm run dev` — Vite mode: development)
# See `.env.staging.example` / `.env.production.example` for other modes.

VITE_APP_ENV=development

# Stripe test publishable key — https://dashboard.stripe.com/test/apikeys
VITE_STRIPE_KEY=pk_test_your_publishable_key_here

# Backend — no trailing slash. Required when VITE_USE_MOCK=false
VITE_API_URL=http://localhost:5000

# Use mockApi.ts when true; set false to call VITE_API_URL
VITE_USE_MOCK=true

# Firebase (client) — from Firebase Console → Project settings → Your apps → SDK setup
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=rentarah.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=rentarah
VITE_FIREBASE_STORAGE_BUCKET=rentarah.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# GitHub Pages project site only: VITE_BASE=/repo-name/
VITE_BASE=/

# Govt ID onboarding — omit or any value except "false" = auto-approve after upload (demos).
# Use VITE_ID_VERIFICATION_INSTANT_APPROVE=false once you enqueue docs for ops review via API/storage.
VITE_ID_VERIFICATION_INSTANT_APPROVE=true
