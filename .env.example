# Stripe test publishable key — get one at https://dashboard.stripe.com/test/apikeys
VITE_STRIPE_KEY=pk_test_your_publishable_key_here

# Backend (Node/Express or Nest) — no trailing slash. Required when VITE_USE_MOCK=false
VITE_API_URL=https://api.example.com

# Use static mock data (mockApi.ts) when true. Set to false to call VITE_API_URL
VITE_USE_MOCK=true
