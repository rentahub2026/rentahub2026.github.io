# Production — copy to `.env.production` for local prod builds: npm run build / npm run build:production
# CI/CD should inject the same variables in the build environment instead of committing secrets.

VITE_APP_ENV=production

VITE_API_URL=https://api.example.com

VITE_USE_MOCK=false

# Live Stripe publishable key in real production
VITE_STRIPE_KEY=pk_live_your_key

VITE_BASE=/
